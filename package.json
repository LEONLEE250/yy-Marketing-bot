{
  "name": "yizhun-wechat-bot",
  "version": "4.0.5",
  "description": "壹准AI营销助手 - 微信群发 + AI文案 + 定时发送 + 朋友圈",
  "main": "frontend/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "backend": "python backend/app.py"
  },
  "author": "壹准",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.yizhun.wechat-bot.preview",
    "productName": "壹准AI营销助手",
    "directories": {
      "output": "build"
    },
    "files": [
      "frontend/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/",
        "to": "backend/"
      },
      {
        "from": "wechat-wxauto/",
        "to": "wechat-wxauto/"
      },
      {
        "from": "moment_dist/moment_publisher.exe",
        "to": "moment_publisher.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "frontend/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "frontend/icon.ico",
      "installerHeaderIcon": "frontend/icon.ico"
    }
  },
  "dependencies": {
    "patchright": "^1.61.1"
  }
}
